#!/bin/bash

if [ $# -ne 1 ]; then
    echo "Usage: "$0" <directory_path>"
    echo "A latest-dump.sql.gz file will be dumped to the specified directory"
    exit 1
fi

directory_path=$1

if [ ! -d "$directory_path" ]; then
    echo "$directory_path does not exist."
    exit 1
fi

docker_flags=''
if [ -t 1 ]; then
    # Got tty
    docker_flags='-it'
fi

docker run \
    $docker_flags \
    --rm \
    --user={{ postgis_container_uid }}:{{ postgis_container_gid }} \
    --cap-drop=ALL \
    --env-file={{ postgis_base_path }}/env-postgres-psql \
    {% if postgis_cli_use_unix_socket_enabled %}
    --mount type=bind,src={{ postgis_run_path }},dst={{ postgis_run_path_in_container }} \
    {% else %}
    --network={{ postgis_container_network }} \
    {% endif %}
    --mount type=bind,src=$directory_path,dst=/out \
    --entrypoint={{ postgis_container_shell_path }} \
    {{ postgis_container_image_to_use }} \
    -c \
    'set -o pipefail && pg_dumpall -h {{ postgis_run_path_in_container if postgis_cli_use_unix_socket_enabled else postgis_connection_hostname }} | zstd --stdout > /out/latest-dump.sql.zst'
